# =====================================================================
# Backoffice front (Next.js) — variables d'environnement
# Copier ce fichier en .env.local puis adapter les valeurs.
# =====================================================================

# URL de base de l'API admin Laravel (sans slash final).
# Doit pointer vers le groupe de routes /admin.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/admin

# URL publique du portfolio/blog (sert à générer les liens "Voir l'article",
# "Voir le portfolio", la prévisualisation, etc.). Laisser vide si non utilisé.
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# --- Identité de marque (réutilisable) ---
# Nom affiché dans la sidebar, les titres de page et le manifeste PWA.
# BRAND_SHORT est optionnel : sinon les initiales sont dérivées du nom.
NEXT_PUBLIC_BRAND_NAME="Mon Portfolio"
NEXT_PUBLIC_BRAND_SHORT="MP"

# (Optionnel) Notifications push web — clé publique VAPID.
# Générer une paire avec : npx web-push generate-vapid-keys
# La clé privée reste côté serveur (API Laravel), jamais ici.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
